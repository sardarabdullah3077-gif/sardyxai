# SARDYX AI Environment Configuration
# Unified settings for Supabase and FreeLLMAPI core services.

# --- LLM PARAMETERS (FreeLLMAPI & Fallback) ---
# Your primary self-hosted or proxy OpenAI-compatible API base URL (e.g., vLLM, Ollama, OpenRouter)
FREE_LLM_API_BASE_URL="https://api.yourfreellmapi.com"
FREE_LLM_API_KEY="freellm_api_unified_integration_key_sec"

# --- DATABASE & STORAGE (SUPABASE INTEGRATIONS) ---
# Supabase project variables for central workspace storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5..."

# --- SYSTEM & DEPLOYMENT PARAMETERS ---
# Internal server url of the deployed app
APP_URL="http://localhost:3000"


# ==============================================================================
#                      SARDYX AI SETUP & DEPLOYMENT GUIDE
# ==============================================================================
#
# LOCAL INSTALLATION:
# 1. Clone or download workspace contents into your local repository.
# 2. Run dependency installation:
#    npm install
# 3. Create a `.env` file from this template and configure keys.
# 4. Start the interactive local development server:
#    npm run dev
# 5. Access the user interface via: http://localhost:3000
#
# DEPLOYMENT GUIDE:
# 1. Build Phase:
#    During build, the frontend is compiled via Vite, and the custom backend ts
#    server is bundled into a self-contained CommonJS index at `dist/server.cjs`
#    using esbuild (run `npm run build`).
# 2. Execution Phase:
#    Run `npm run start` to spin up the production container listener on port 3000.
#
# SECURITY COMPLIANCE NOTE:
# - All NextAuth, Google OAuth client secrets, and Google Client IDs have been
#   deprecate-purged to guarantee clean compliance. Only use custom email-based authorization
#   or simulated Google Single Sign-In to handshake local sessions.
# - Keep FREE_LLM_API_KEY and SUPABASE keys secure; never expose them to frontends.
